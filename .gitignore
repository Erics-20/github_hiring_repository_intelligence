# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments ─────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Secrets / API keys ───────────────────────────────────────
.env
.env.*
secrets.json
config_local.py

# ── Datos (pueden ser pesados) ───────────────────────────────
data/raw/*
data/processed/*
data/labeled/*
data/splits/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/labeled/.gitkeep
!data/splits/.gitkeep

# ── Modelos entrenados ───────────────────────────────────────
models/trained_models/*
!models/trained_models/.gitkeep

# ── Outputs generados ────────────────────────────────────────
output/figures/*
output/tables/*
output/metrics/*
!output/figures/.gitkeep
!output/tables/.gitkeep
!output/metrics/.gitkeep

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── VS Code ──────────────────────────────────────────────────
.vscode/
*.code-workspace

# ── Streamlit cache ──────────────────────────────────────────
.streamlit/

# ── Pytest / coverage ────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
